rules_version = '2';
// Deploy to database: ai-studio-9667486d-fba1-4a51-ab55-63a8264bd412
// (AI Studio / named DB). Rules pasted only under "(default)" in the console do NOT apply to this app.
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, 'teacher' or 'student')
    //
    // Collection: classes
    // Document ID: classId
    // Fields:
    //   - id: string
    //   - name: string (required)
    //   - description: string
    //   - teacherId: string (required)
    //   - studentIds: list (required)
    //   - inviteCode: string (required)
    //
    // Collection: assessments
    // Document ID: assessmentId
    // Fields:
    //   - id: string
    //   - classId: string (required)
    //   - title: string (required)
    //   - prompt: string (required)
    //   - rubric: map (required)
    //   - dueDate: timestamp
    //
    // Collection: submissions
    // Document ID: submissionId
    // Fields:
    //   - id: string
    //   - assessmentId: string (required)
    //   - studentId: string (required)
    //   - content: string (required)
    //   - score: number (current / teacher-final)
    //   - feedback: string (current / teacher-final)
    //   - aiScore, aiFeedback: snapshot when AI graded (immutable after set)
    //   - teacherRevisedAt: optional ISO string when teacher saves a revision
    //   - status: string (required, 'pending', 'graded', 'revised')
    //   - submittedAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Safe read: accessing .data when the doc is missing breaks rule evaluation.
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isTeacher() {
      return isAuthenticated() && userDoc().exists && userDoc().data.role == 'teacher';
    }

    function isStudent() {
      return isAuthenticated() && userDoc().exists && userDoc().data.role == 'student';
    }

    function isAdmin() {
      return isAuthenticated() && (
        (userDoc().exists && userDoc().data.role == 'admin') ||
        (request.auth.token.email == "Manyavr30@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    // Once set by AI grading, aiScore / aiFeedback must not change (teacher revisions only touch score, feedback, status).
    function preservesSubmissionAiSnapshot() {
      return (!resource.data.keys().hasAll(['aiFeedback'])
          || request.resource.data.aiFeedback == resource.data.aiFeedback)
        && (!resource.data.keys().hasAll(['aiScore'])
          || request.resource.data.aiScore == resource.data.aiScore);
    }

    // Join class: only studentIds changes, all previous IDs kept, exactly one new ID (must be caller).
    // Matches Firestore arrayUnion(self) without needing users/{uid} for isStudent().
    function isJoiningClassByCode() {
      let oldIds = resource.data.studentIds;
      let newIds = request.resource.data.studentIds;
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentIds'])
        && newIds.hasAll(oldIds)
        && newIds.size() == oldIds.size() + 1
        && request.auth.uid in newIds
        && !(request.auth.uid in oldIds);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.role in ['teacher', 'student'];
    }

    // Assessments store classId, not teacherId — use class to resolve the teacher.
    function isTeacherOfAssessment(assessmentId) {
      let a = get(/databases/$(database)/documents/assessments/$(assessmentId));
      return a.exists
        && get(/databases/$(database)/documents/classes/$(a.data.classId)).exists
        && get(/databases/$(database)/documents/classes/$(a.data.classId)).data.teacherId == request.auth.uid;
    }

    // Class owner by classId (avoids isTeacher() which needs users/{uid}.role — often missing for collaborators).
    function isTeacherOfClassId(classId) {
      let c = get(/databases/$(database)/documents/classes/$(classId));
      return c.exists && c.data.teacherId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      // Allow role changes so login can set teacher vs student (setDoc after Google sign-in).
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /classes/{classId} {
      // Any signed-in user may read (needed to query by inviteCode before the student is in studentIds).
      allow read: if isAuthenticated();
      // For class creation, trust the document's teacherId ownership instead of depending on users/{uid}.role.
      // This avoids false "permission-denied" when role docs are missing/stale during auth transitions.
      allow create: if isAuthenticated() && request.resource.data.teacherId == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.teacherId ||
        isJoiningClassByCode()
      );
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.teacherId;
    }

    match /assessments/{assessmentId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher();
      allow update: if isTeacher() && request.auth.uid == get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.teacherId;
      allow delete: if isTeacher() && request.auth.uid == get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.teacherId;
    }

    match /submissions/{submissionId} {
      // Reads: any signed-in user (POC). Rules using get()/isTeacher() break Firestore *list*
      // queries (Missing permission). The app only queries by assessmentId / studentId.
      // Tighten for production (e.g. Cloud Function or denormalized fields + matching where).
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAuthenticated()
        && preservesSubmissionAiSnapshot()
        && (
        (request.auth.uid == resource.data.studentId && resource.data.status == 'pending') ||
        request.auth.uid == resource.data.teacherId ||
        isTeacherOfAssessment(resource.data.assessmentId)
      );
    }
  }
}
