# Server port (default 3000 locally; Docker/AWS often use 8080)
# PORT=8080

# Required for AI grading (Express). Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Required so the server can update Firestore after grading (student may close the tab).
# Option A: path to a service account JSON file (local dev)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json
#
# Option B: paste the full JSON (one line) for hosted environments
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Create a key: Firebase console → Project settings → Service accounts → Generate new private key.
# The account needs permission to read/write Firestore for this project.
